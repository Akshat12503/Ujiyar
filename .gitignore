**/App_Data/*.ldf

# --- Node & Frontend Package Debug Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDEs, Editors & Cache Spaces ---
.idea/
.project
.classpath
*.sublime-workspace
.history/
.sass-cache/
